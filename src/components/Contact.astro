---
import { content, defaultLanguage } from "../data/content";

const t = content[defaultLanguage];
---

<section id="contact" class="section">
  <p class="label" data-i18n="contact.label">{t.contact.label}</p>
  <h2 data-i18n="contact.title">{t.contact.title}</h2>
  <p data-i18n="contact.body">{t.contact.body}</p>
  <div class="contact-actions">
    <a class="button" href={`mailto:${t.contact.email}`} data-i18n="contact.cta">
      {t.contact.cta}
    </a>
    <a class="email-link" href={`mailto:${t.contact.email}`} data-i18n="contact.email">
      {t.contact.email}
    </a>
    <div
      class="social-links"
      aria-label={t.contact.socialLabel}
      data-i18n="contact.socialLabel"
      data-i18n-attr="aria-label"
      data-i18n-mode="attr"
    >
      <a
        href="https://github.com/kumina"
        aria-label="GitHub"
        class="social-link"
        target="_blank"
        rel="noreferrer"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M12 2C6.48 2 2 6.58 2 12.26c0 4.52 2.87 8.35 6.84 9.71.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.72-2.78.62-3.37-1.37-3.37-1.37-.45-1.17-1.1-1.48-1.1-1.48-.9-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.15-4.56-5.12 0-1.13.39-2.06 1.03-2.79-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05.8-.23 1.66-.34 2.52-.34.86 0 1.72.12 2.52.34 1.91-1.32 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.73 1.03 1.66 1.03 2.79 0 3.98-2.34 4.85-4.57 5.11.36.32.68.95.68 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.18.6.69.49 3.97-1.37 6.83-5.2 6.83-9.71C22 6.58 17.52 2 12 2z"
          />
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/kumina"
        aria-label="LinkedIn"
        class="social-link"
        target="_blank"
        rel="noreferrer"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path
            fill="currentColor"
            d="M19 3A2 2 0 0 1 21 5v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zm-9.75 16.5v-9h-3v9h3zm-1.5-10.28c.97 0 1.75-.8 1.75-1.78s-.78-1.78-1.75-1.78-1.75.8-1.75 1.78.78 1.78 1.75 1.78zm11.25 10.28v-5.15c0-2.76-1.47-4.05-3.43-4.05-1.58 0-2.29.87-2.69 1.48v-1.27h-3c.04.84 0 9 0 9h3v-5.03c0-.27.02-.54.1-.73.22-.54.72-1.1 1.56-1.1 1.1 0 1.54.84 1.54 2.08v4.78h2.92z"
          />
        </svg>
      </a>
    </div>
  </div>
</section>
