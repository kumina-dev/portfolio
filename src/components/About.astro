---
import { content, defaultLanguage } from "../data/content";

const t = content[defaultLanguage];
---

<section id="about" class="section">
  <p class="label" data-i18n="about.label">{t.about.label}</p>
  <h2 data-i18n="about.title">{t.about.title}</h2>
  <p data-i18n="about.body">{t.about.body}</p>
  <div class="glow-divider" aria-hidden="true"></div>
</section>
