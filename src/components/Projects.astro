---
import { content, defaultLanguage } from "../data/content";

const t = content[defaultLanguage];
---

<section id="projects" class="section">
  <p class="label" data-i18n="projects.label">{t.projects.label}</p>
  <h2 data-i18n="projects.title">{t.projects.title}</h2>
  <div class="card-grid">
    {t.projects.items.map((project, index) => (
      <article class="card project-card" data-project-id={project.id}>
        <h3 data-i18n={`projects.items.${index}.title`}>{project.title}</h3>
        <p data-i18n={`projects.items.${index}.summary`}>{project.summary}</p>
        <p class="card-meta">
          <span data-i18n="projects.techLabel">{t.projects.techLabel}</span>:{" "}
          <span data-i18n={`projects.items.${index}.tech`}>{project.tech}</span>
        </p>
        <div
          class="screenshot-placeholder"
          data-i18n={`projects.items.${index}.screenshotLabel`}
          data-i18n-attr="aria-label"
          aria-label={project.screenshotLabel}
        >
          {project.screenshotLabel}
        </div>
        <button class="button ghost-button" type="button" data-project-open={project.id}>
          <span data-i18n="projects.openButton">{t.projects.openButton}</span>
        </button>
      </article>
    ))}
  </div>
  <dialog
    class="project-modal"
    id="project-modal"
    aria-label={t.projects.modalLabel}
    data-i18n="projects.modalLabel"
    data-i18n-attr="aria-label"
    data-i18n-mode="attr"
  >
    <div class="modal-content">
      <header class="modal-header">
        <div>
          <p class="label" data-i18n="projects.modalLabel">{t.projects.modalLabel}</p>
          <h3 class="modal-title" data-modal="title"></h3>
        </div>
        <button class="modal-close" type="button" data-modal-close>
          <span data-i18n="projects.closeButton">{t.projects.closeButton}</span>
        </button>
      </header>
      <div class="modal-body">
        <h4 class="modal-heading" data-i18n="projects.overviewLabel">{t.projects.overviewLabel}</h4>
        <p class="modal-summary" data-modal="summary"></p>
        <h4 class="modal-heading" data-i18n="projects.highlightsLabel">{t.projects.highlightsLabel}</h4>
        <ul class="modal-list" data-modal="highlights"></ul>
        <p class="modal-tech">
          <span class="modal-tech-label" data-i18n="projects.techLabel">{t.projects.techLabel}</span>
          <span data-modal="tech"></span>
        </p>
      </div>
    </div>
  </dialog>
</section>
