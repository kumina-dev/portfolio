---
import { content, defaultLanguage } from "../data/content";
import { getLocalizedString } from "../utils/i18n";

const t = content[defaultLanguage];
const i18n = getLocalizedString;
const projectsLabelKey = "projects.label";
const projectsTitleKey = "projects.title";
const projectsTechLabelKey = "projects.techLabel";
const projectsOpenButtonKey = "projects.openButton";
const projectsModalLabelKey = "projects.modalLabel";
const projectsCloseButtonKey = "projects.closeButton";
const projectsOverviewLabelKey = "projects.overviewLabel";
const projectsHighlightsLabelKey = "projects.highlightsLabel";
const projectsShareLabelKey = "projects.shareLabel";
const projectsShareLinkKey = "projects.shareLink";
const itemKey = (index: number, field: string) => `projects.items.${index}.${field}`;
---

<section id="projects" class="section">
  <div class="section-header">
    <p class="label" data-i18n={projectsLabelKey}>{i18n(projectsLabelKey)}</p>
    <h2 data-i18n={projectsTitleKey}>{i18n(projectsTitleKey)}</h2>
  </div>
  <div class="section-body">
    <div class="card-grid">
      {t.projects.items.map((project, index) => (
        <article class="card project-card" data-project-id={project.id}>
          <h3 data-i18n={itemKey(index, "title")}>{i18n(itemKey(index, "title"))}</h3>
          <p data-i18n={itemKey(index, "summary")}>{i18n(itemKey(index, "summary"))}</p>
          <div class="project-media">
            <div
              class="project-frame"
              data-i18n={itemKey(index, "screenshotLabel")}
              data-i18n-attr="aria-label"
              aria-label={project.screenshotLabel}
            >
              <span class="project-frame-label">{i18n(itemKey(index, "screenshotLabel"))}</span>
            </div>
          </div>
          <p class="card-meta">
            <span data-i18n={projectsTechLabelKey}>{i18n(projectsTechLabelKey)}</span>:{" "}
            <span data-i18n={itemKey(index, "tech")}>{i18n(itemKey(index, "tech"))}</span>
          </p>
          <div class="project-actions">
            <button class="button ghost ghost-button" type="button" data-project-open={project.id}>
              <span data-i18n={projectsOpenButtonKey}>{i18n(projectsOpenButtonKey)}</span>
            </button>
            <a
              class="button ghost ghost-button"
              href={`#project-${project.id}`}
              data-project-share={project.id}
              data-i18n={projectsShareLinkKey}
            >
              {i18n(projectsShareLinkKey)}
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
  <dialog
    class="project-modal"
    id="project-modal"
    aria-label={i18n(projectsModalLabelKey)}
    data-i18n={projectsModalLabelKey}
    data-i18n-attr="aria-label"
    data-i18n-mode="attr"
  >
    <div class="modal-content">
      <header class="modal-header">
        <div>
          <p class="label" data-i18n={projectsModalLabelKey}>{i18n(projectsModalLabelKey)}</p>
          <h3 class="modal-title" data-modal="title"></h3>
        </div>
        <button class="modal-close" type="button" data-modal-close>
          <span data-i18n={projectsCloseButtonKey}>{i18n(projectsCloseButtonKey)}</span>
        </button>
      </header>
      <div class="modal-body">
        <h4 class="modal-heading" data-i18n={projectsOverviewLabelKey}>
          {i18n(projectsOverviewLabelKey)}
        </h4>
        <p class="modal-summary" data-modal="summary"></p>
        <h4 class="modal-heading" data-i18n={projectsHighlightsLabelKey}>
          {i18n(projectsHighlightsLabelKey)}
        </h4>
        <ul class="modal-list" data-modal="highlights"></ul>
        <p class="modal-tech">
          <span class="modal-tech-label" data-i18n={projectsTechLabelKey}>
            {i18n(projectsTechLabelKey)}
          </span>
          <span data-modal="tech"></span>
        </p>
        <div class="modal-share">
          <span class="modal-share-label" data-i18n={projectsShareLabelKey}>
            {i18n(projectsShareLabelKey)}
          </span>
          <a class="modal-share-link" data-modal="share" data-i18n={projectsShareLinkKey}>
            {i18n(projectsShareLinkKey)}
          </a>
        </div>
      </div>
    </div>
  </dialog>
</section>
