---
import { content, defaultLanguage } from "../data/content";

const t = content[defaultLanguage];
---

<section id="notes" class="section">
  <p class="label" data-i18n="notes.label">{t.notes.label}</p>
  <h2 data-i18n="notes.title">{t.notes.title}</h2>
  <div class="notes-list">
    {t.notes.items.map((note, index) => (
      <article>
        <h3 data-i18n={`notes.items.${index}.title`}>{note.title}</h3>
        <p data-i18n={`notes.items.${index}.body`}>{note.body}</p>
      </article>
    ))}
  </div>
</section>
