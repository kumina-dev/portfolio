---
import { getLocalizedString } from "../utils/i18n";

const t = getLocalizedString;
const heroLabelKey = "hero.label";
const heroNameKey = "hero.name";
const heroLocationKey = "hero.location";
const heroStatusKey = "hero.status";
const heroCtaPrimaryKey = "hero.ctaPrimary";
const heroCtaSecondaryKey = "hero.ctaSecondary";
const heroHeadshotAltKey = "hero.headshotAlt";
const navAboutKey = "nav.about";
const navSkillsKey = "nav.skills";
const navProjectsKey = "nav.projects";
const navExperienceKey = "nav.experience";
const navBlogKey = "nav.blog";
const navContactKey = "nav.contact";
const languageLabelKey = "languageSwitcher.label";
const languageEnglishKey = "languageSwitcher.english";
const languageFinnishKey = "languageSwitcher.finnish";
---

<header class="site-header">
  <div class="hero-grid">
    <div class="hero-portrait">
      <img
        src="/headshot.svg"
        alt={t(heroHeadshotAltKey)}
        data-i18n={heroHeadshotAltKey}
        data-i18n-attr="alt"
        data-i18n-mode="attr"
        loading="lazy"
      />
      <span class="hero-portrait-glow" aria-hidden="true"></span>
    </div>
    <div class="hero-copy">
      <p class="label" data-i18n={heroLabelKey}>{t(heroLabelKey)}</p>
      <h1 data-i18n={heroNameKey}>{t(heroNameKey)}</h1>
      <p class="hero-meta" data-i18n={heroLocationKey}>{t(heroLocationKey)}</p>
      <p class="status-chip" data-i18n={heroStatusKey}>{t(heroStatusKey)}</p>
      <div class="hero-actions">
        <a
          class="button primary"
          href="#projects"
          data-section-link="projects"
          data-i18n={heroCtaPrimaryKey}
        >
          {t(heroCtaPrimaryKey)}
        </a>
        <a
          class="button ghost"
          href="#contact"
          data-section-link="contact"
          data-i18n={heroCtaSecondaryKey}
        >
          {t(heroCtaSecondaryKey)}
        </a>
      </div>
    </div>
  </div>
  <div class="nav-row">
    <nav aria-label="Primary" class="top-nav">
      <ul class="top-nav-list">
        <li>
          <a
            href="#about"
            data-section-link="about"
            data-i18n={navAboutKey}
            aria-current="page"
          >
            {t(navAboutKey)}
          </a>
        </li>
        <li>
          <a href="#skills" data-section-link="skills" data-i18n={navSkillsKey}>
            {t(navSkillsKey)}
          </a>
        </li>
        <li>
          <a href="#projects" data-section-link="projects" data-i18n={navProjectsKey}>
            {t(navProjectsKey)}
          </a>
        </li>
        <li>
          <a href="#experience" data-section-link="experience" data-i18n={navExperienceKey}>
            {t(navExperienceKey)}
          </a>
        </li>
        <li>
          <a href="#blog" data-section-link="blog" data-i18n={navBlogKey}>
            {t(navBlogKey)}
          </a>
        </li>
        <li>
          <a href="#contact" data-section-link="contact" data-i18n={navContactKey}>
            {t(navContactKey)}
          </a>
        </li>
      </ul>
    </nav>
    <div class="language-switcher" aria-label="Language switcher">
      <span class="label" data-i18n={languageLabelKey}>{t(languageLabelKey)}</span>
      <div class="language-buttons" role="group" aria-label="Language">
        <button type="button" class="language-button" data-lang="en">
          <span data-i18n={languageEnglishKey}>{t(languageEnglishKey)}</span>
        </button>
        <button type="button" class="language-button" data-lang="fi">
          <span data-i18n={languageFinnishKey}>{t(languageFinnishKey)}</span>
        </button>
      </div>
    </div>
  </div>
</header>
