<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Kumina | Portfolio</title>
	</head>
	<body>
		<main>
			<header>
				<p class="label">Ville</p>
				<h1>Kumina</h1>
				<p>
					Software developer building consumer-friendly experiences with a focus on
					security and privacy.
				</p>
				<p class="label">Beginner → Intermediate (3+ years learning by building)</p>
				<div class="glow-divider" aria-hidden="true"></div>
				<nav aria-label="Primary">
					<a href="#projects">View Projects</a>
					<a href="#contact">Contact Me</a>
				</nav>
			</header>
		</main>
		<style>
			:root {
				color-scheme: dark;
				--bg: #0b0c12;
				--surface: rgba(19, 21, 32, 0.75);
				--accent: #7c5cff;
				--text: #f5f5ff;
				--muted: #b6bdd9;
				--border: rgba(124, 92, 255, 0.4);
				--glow: rgba(124, 92, 255, 0.35);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: radial-gradient(circle at top, rgba(124, 92, 255, 0.15), transparent 45%),
					var(--bg);
				color: var(--text);
				font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
				display: flex;
				justify-content: center;
				align-items: center;
				padding: 3.5rem 1.5rem;
			}

			main {
				max-width: 720px;
				width: 100%;
				background: var(--surface);
				border: 1px solid rgba(124, 92, 255, 0.2);
				box-shadow: 0 0 30px rgba(7, 9, 18, 0.9);
				border-radius: 24px;
				padding: 3rem;
				backdrop-filter: blur(12px);
			}

			header {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			h1 {
				font-size: clamp(2.5rem, 4vw, 3.6rem);
				margin: 0;
				letter-spacing: 0.02em;
			}

			p {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.6;
				color: var(--muted);
			}

			.label {
				font-family: "IBM Plex Mono", "SFMono-Regular", "Fira Code", monospace;
				font-size: 0.85rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--text);
			}

			nav {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}

			nav a {
				text-decoration: none;
				color: var(--text);
				border: 1px solid var(--border);
				padding: 0.75rem 1.4rem;
				border-radius: 999px;
				font-weight: 500;
				letter-spacing: 0.02em;
				background: rgba(12, 14, 24, 0.6);
				box-shadow: 0 0 18px transparent;
				transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
			}

			nav a:hover {
				border-color: var(--accent);
				box-shadow: 0 0 18px var(--glow);
				transform: translateY(-2px);
			}

			.glow-divider {
				height: 2px;
				border-radius: 999px;
				background: linear-gradient(90deg, transparent, var(--accent), transparent);
				box-shadow: 0 0 14px var(--glow);
				animation: pulse 6s ease-in-out infinite;
				opacity: 0.7;
			}

			@keyframes pulse {
				0%,
				100% {
					filter: brightness(0.8);
					transform: scaleX(0.98);
				}
				50% {
					filter: brightness(1.2);
					transform: scaleX(1);
				}
			}
		</style>
	</body>
</html>
