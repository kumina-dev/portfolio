		<style>
			:root {
				color-scheme: dark;
				--bg: #0b0c12;
				--surface: rgba(19, 21, 32, 0.75);
				--accent: #7c5cff;
				--text: #f5f5ff;
				--muted: #b6bdd9;
				--border: rgba(124, 92, 255, 0.4);
				--glow: rgba(124, 92, 255, 0.35);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: radial-gradient(circle at top, rgba(124, 92, 255, 0.15), transparent 45%),
					var(--bg);
				color: var(--text);
				font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
				display: flex;
				justify-content: center;
				align-items: flex-start;
				padding: 3.5rem 1.5rem 6rem;
			}

			main {
				max-width: 880px;
				width: 100%;
				background: var(--surface);
				border: 1px solid rgba(124, 92, 255, 0.2);
				box-shadow: 0 0 30px rgba(7, 9, 18, 0.9);
				border-radius: 24px;
				padding: 3rem;
				backdrop-filter: blur(12px);
				display: flex;
				flex-direction: column;
				gap: 3rem;
			}

			.site-header {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			h1 {
				font-size: clamp(2.5rem, 4vw, 3.6rem);
				margin: 0;
				letter-spacing: 0.02em;
			}

			h2 {
				margin: 0 0 0.75rem;
				font-size: clamp(1.6rem, 3vw, 2.2rem);
			}

			h3 {
				margin: 0 0 0.35rem;
				font-size: 1.1rem;
				color: var(--text);
			}

			p {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.6;
				color: var(--muted);
			}

			.headline {
				font-size: 1.15rem;
			}

			.label {
				font-family: "IBM Plex Mono", "SFMono-Regular", "Fira Code", monospace;
				font-size: 0.85rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--text);
			}

			.top-nav {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
			}

			.top-nav a {
				text-decoration: none;
				color: var(--text);
				border: 1px solid var(--border);
				padding: 0.65rem 1.2rem;
				border-radius: 999px;
				font-weight: 500;
				letter-spacing: 0.02em;
				background: rgba(12, 14, 24, 0.6);
				box-shadow: 0 0 18px transparent;
				transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
			}

			.top-nav a:hover {
				border-color: var(--accent);
				box-shadow: 0 0 18px var(--glow);
				transform: translateY(-2px);
			}

			.section {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.card-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.25rem;
			}

			.card {
				padding: 1.25rem;
				border-radius: 16px;
				background: rgba(12, 14, 24, 0.6);
				border: 1px solid rgba(124, 92, 255, 0.2);
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.card-meta {
				font-size: 0.95rem;
				color: rgba(245, 245, 255, 0.75);
			}

			.screenshot-placeholder {
				border-radius: 12px;
				border: 1px dashed rgba(124, 92, 255, 0.5);
				background: rgba(12, 14, 24, 0.35);
				color: rgba(245, 245, 255, 0.7);
				padding: 1rem;
				text-align: center;
				font-size: 0.9rem;
				letter-spacing: 0.02em;
			}

			.notes-list {
				display: grid;
				gap: 1rem;
			}

			.notes-list article {
				padding: 1rem 1.25rem;
				border-radius: 16px;
				background: rgba(12, 14, 24, 0.45);
				border: 1px solid rgba(124, 92, 255, 0.2);
			}

			.timeline {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}

			.timeline li {
				padding: 1rem 1.25rem;
				border-radius: 16px;
				background: rgba(12, 14, 24, 0.45);
				border: 1px solid rgba(124, 92, 255, 0.2);
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				text-decoration: none;
				color: var(--text);
				border: 1px solid var(--border);
				padding: 0.75rem 1.6rem;
				border-radius: 999px;
				font-weight: 600;
				background: rgba(12, 14, 24, 0.6);
				transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
			}

			.button:hover {
				border-color: var(--accent);
				box-shadow: 0 0 18px var(--glow);
				transform: translateY(-2px);
			}

			.contact-actions {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.email-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--text);
				text-decoration: none;
				font-weight: 600;
				font-size: 1.05rem;
				letter-spacing: 0.02em;
			}

			.email-link:hover {
				color: var(--accent);
			}

			.social-links {
				display: flex;
				gap: 0.75rem;
			}

			.social-link {
				width: 44px;
				height: 44px;
				border-radius: 12px;
				border: 1px solid var(--border);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: var(--text);
				background: rgba(12, 14, 24, 0.6);
				transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
			}

			.social-link svg {
				width: 20px;
				height: 20px;
			}

			.social-link:hover {
				border-color: var(--accent);
				box-shadow: 0 0 14px var(--glow);
				transform: translateY(-2px);
			}

			.glow-divider {
				height: 2px;
				border-radius: 999px;
				background: linear-gradient(90deg, transparent, var(--accent), transparent);
				box-shadow: 0 0 14px var(--glow);
				animation: pulse 6s ease-in-out infinite;
				opacity: 0.7;
				margin-top: 1.5rem;
			}

			@keyframes pulse {
				0%,
				100% {
					filter: brightness(0.8);
					transform: scaleX(0.98);
				}
				50% {
					filter: brightness(1.2);
					transform: scaleX(1);
				}
			}

			@media (max-width: 640px) {
				main {
					padding: 2.5rem 1.75rem;
				}

				.top-nav {
					gap: 0.5rem;
				}

				.top-nav a {
					padding: 0.55rem 1rem;
				}
			}
		</style>
	</body>
</html>
