---
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Skills from "../components/Skills.astro";
import Projects from "../components/Projects.astro";
import Experience from "../components/Experience.astro";
import Blog from "../components/Blog.astro";
import Contact from "../components/Contact.astro";
import { content, defaultLanguage } from "../data/content";

const t = content[defaultLanguage];
---

<html lang={defaultLanguage}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{t.meta.title}</title>
		<script is:inline define:vars={{ content, defaultLanguage }}>
			const contentData = content;
			const supportedLanguages = Object.keys(contentData);
			const storedLanguage = localStorage.getItem("language");
			const resolvedLanguage = supportedLanguages.includes(storedLanguage)
				? storedLanguage
				: defaultLanguage;
			document.documentElement.lang = resolvedLanguage;
			document.title = contentData[resolvedLanguage]?.meta?.title ?? document.title;
			window.__preferredLanguage = resolvedLanguage;
		</script>
			<script is:inline type="module" define:vars={{ content, defaultLanguage }}>
				const contentData = content;
				const defaultLanguageValue = defaultLanguage;
				const languageButtons = document.querySelectorAll("[data-lang]");
				const i18nElements = document.querySelectorAll("[data-i18n]");
				const localizedBlocks = document.querySelectorAll("[data-locale]");
				const modal = document.querySelector("#project-modal");
				const openButtons = document.querySelectorAll("[data-project-open]");
			const modalClose = modal?.querySelector("[data-modal-close]");
			const modalTitle = modal?.querySelector("[data-modal='title']");
			const modalSummary = modal?.querySelector("[data-modal='summary']");
			const modalHighlights = modal?.querySelector("[data-modal='highlights']");
			const modalTech = modal?.querySelector("[data-modal='tech']");
			let activeLanguage = defaultLanguageValue;
			let activeProjectId = null;

			const getValue = (lang, key) => {
				return key.split(".").reduce((acc, part) => acc && acc[part], contentData[lang]);
			};

			const getProject = (lang, id) => {
				return contentData[lang]?.projects?.items?.find((item) => item.id === id);
			};

			const renderModal = (project) => {
				if (!project || !modalTitle || !modalSummary || !modalHighlights || !modalTech) return;
				modalTitle.textContent = project.title;
				modalSummary.textContent = project.summary;
				modalTech.textContent = project.tech;
				modalHighlights.innerHTML = "";
				project.highlights.forEach((highlight) => {
					const item = document.createElement("li");
					item.textContent = highlight;
					modalHighlights.appendChild(item);
				});
			};

				const applyLanguage = (lang) => {
					activeLanguage = lang;
					document.documentElement.lang = lang;
					document.title = contentData[lang]?.meta?.title ?? document.title;
					i18nElements.forEach((el) => {
					const key = el.dataset.i18n;
					if (!key) return;
					const value = getValue(lang, key);
					if (typeof value !== "string") return;
					const attrList = el.dataset.i18nAttr;
					if (attrList) {
						attrList.split(",").forEach((attr) => {
							if (attr.trim()) {
								el.setAttribute(attr.trim(), value);
							}
						});
					}
					if (el.dataset.i18nMode !== "attr") {
						el.textContent = value;
					}
					});
					localizedBlocks.forEach((el) => {
						const locale = el.dataset.locale;
						if (!locale) return;
						el.hidden = locale !== lang;
					});
					languageButtons.forEach((button) => {
						const isActive = button.dataset.lang === lang;
						button.setAttribute("aria-pressed", String(isActive));
					button.classList.toggle("is-active", isActive);
				});
				if (activeProjectId && modal?.open) {
					const project = getProject(lang, activeProjectId);
					renderModal(project);
				}
			};

			const openModal = (projectId) => {
				const project = getProject(activeLanguage, projectId);
				if (!project || !modal) return;
				activeProjectId = projectId;
				renderModal(project);
				modal.showModal();
			};

			const closeModal = () => {
				if (!modal) return;
				modal.close();
			};

			const savedLanguage = window.__preferredLanguage ?? defaultLanguageValue;
			applyLanguage(savedLanguage);

			languageButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const nextLang = button.dataset.lang;
					if (!nextLang) return;
					localStorage.setItem("language", nextLang);
					applyLanguage(nextLang);
				});
			});

			openButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const projectId = button.dataset.projectOpen;
					if (projectId) {
						openModal(projectId);
					}
				});
			});

			modalClose?.addEventListener("click", closeModal);
			modal?.addEventListener("cancel", closeModal);
			modal?.addEventListener("click", (event) => {
				if (event.target === modal) {
					closeModal();
				}
			});
		</script>
	</head>
	<body>
		<main>
			<Hero />
			<About />
			<Skills />
			<Projects />
			<Experience />
			<Blog />
			<Contact />
		</main>
		<style is:global>
			:root {
				color-scheme: dark;
				--bg: #05060c;
				--surface: rgba(13, 16, 30, 0.82);
				--surface-strong: rgba(9, 12, 24, 0.9);
				--accent: #55f2ff;
				--accent-strong: #9b5bff;
				--accent-pink: #ff4fd8;
				--text: #f5f7ff;
				--muted: #a9b2d8;
				--border: rgba(85, 242, 255, 0.35);
				--glow: rgba(85, 242, 255, 0.35);
				--overlay: rgba(5, 6, 12, 0.85);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: radial-gradient(circle at top, rgba(155, 91, 255, 0.18), transparent 45%),
					radial-gradient(circle at 25% 15%, rgba(85, 242, 255, 0.12), transparent 35%),
					var(--bg);
				color: var(--text);
				font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
				display: flex;
				justify-content: center;
				align-items: flex-start;
				padding: 3.5rem 1.5rem 6rem;
			}

			main {
				max-width: 1040px;
				width: 100%;
				background: var(--surface);
				border: 1px solid rgba(85, 242, 255, 0.2);
				box-shadow: 0 0 40px rgba(6, 8, 18, 0.9), inset 0 0 30px rgba(85, 242, 255, 0.08);
				border-radius: 28px;
				padding: 3.5rem;
				backdrop-filter: blur(12px);
				display: flex;
				flex-direction: column;
				gap: 3rem;
			}

			.site-header {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			.hero-grid {
				display: grid;
				grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
				gap: 2.5rem;
				align-items: center;
			}

			.hero-portrait {
				position: relative;
				border-radius: 20px;
				padding: 0.35rem;
				background: linear-gradient(135deg, rgba(85, 242, 255, 0.5), rgba(255, 79, 216, 0.4));
				box-shadow: 0 0 24px rgba(85, 242, 255, 0.3);
				aspect-ratio: 4 / 5;
				max-width: 320px;
				width: 100%;
				margin: 0 auto;
			}

			.hero-portrait img {
				display: block;
				width: 100%;
				height: 100%;
				border-radius: 16px;
				object-fit: cover;
				background: rgba(6, 8, 18, 0.9);
			}

			.hero-portrait-glow {
				position: absolute;
				inset: 12px;
				border-radius: 18px;
				border: 1px solid rgba(85, 242, 255, 0.35);
				box-shadow: 0 0 24px rgba(85, 242, 255, 0.4);
				pointer-events: none;
			}

			.hero-copy {
				display: flex;
				flex-direction: column;
				gap: 0.6rem;
			}

			.hero-actions {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				margin-top: 1rem;
			}

			h1 {
				font-size: clamp(2.5rem, 4vw, 3.6rem);
				margin: 0;
				letter-spacing: 0.02em;
			}

			h2 {
				margin: 0 0 0.75rem;
				font-size: clamp(1.6rem, 3vw, 2.2rem);
			}

			h3 {
				margin: 0 0 0.35rem;
				font-size: 1.1rem;
				color: var(--text);
			}

			h4 {
				margin: 0;
				font-size: 1rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--muted);
			}

			p {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.6;
				color: var(--muted);
			}

			.headline {
				font-size: 1.2rem;
				color: rgba(245, 247, 255, 0.92);
			}

			.hero-meta {
				font-size: 1rem;
				margin-top: 0.4rem;
				color: rgba(169, 178, 216, 0.9);
			}

			.status-chip {
				margin-top: 0.75rem;
				font-size: 0.9rem;
				padding: 0.35rem 0.9rem;
				border-radius: 999px;
				display: inline-flex;
				border: 1px solid rgba(85, 242, 255, 0.4);
				background: rgba(6, 8, 18, 0.7);
				color: rgba(245, 245, 255, 0.85);
			}

			.label {
				font-family: "IBM Plex Mono", "SFMono-Regular", "Fira Code", monospace;
				font-size: 0.85rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--text);
			}

			.top-nav {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
			}

			.nav-row {
				display: flex;
				align-items: flex-end;
				justify-content: space-between;
				gap: 1.5rem;
				flex-wrap: wrap;
			}

			.language-switcher {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				align-items: flex-start;
			}

			.language-buttons {
				display: inline-flex;
				gap: 0.5rem;
			}

			.language-button {
				border: 1px solid var(--border);
				background: rgba(6, 8, 18, 0.7);
				color: var(--text);
				padding: 0.4rem 0.9rem;
				border-radius: 999px;
				font-weight: 600;
				cursor: pointer;
				transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
			}

			.language-button.is-active {
				border-color: var(--accent);
				box-shadow: 0 0 12px var(--glow);
			}

			.language-button:hover {
				border-color: var(--accent);
				transform: translateY(-1px);
			}

			.top-nav a {
				text-decoration: none;
				color: var(--text);
				border: 1px solid var(--border);
				padding: 0.65rem 1.1rem;
				border-radius: 999px;
				font-weight: 500;
				letter-spacing: 0.02em;
				background: rgba(6, 8, 18, 0.7);
				box-shadow: 0 0 18px transparent;
				transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
			}

			.top-nav a:hover {
				border-color: var(--accent);
				box-shadow: 0 0 18px var(--glow);
				transform: translateY(-2px);
			}

			.section {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				padding: 1.5rem;
				border-radius: 20px;
				background: linear-gradient(160deg, rgba(10, 14, 30, 0.9), rgba(8, 10, 20, 0.7));
				border: 1px solid rgba(85, 242, 255, 0.12);
				box-shadow: inset 0 0 12px rgba(85, 242, 255, 0.08);
			}

			.card-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
				gap: 1.25rem;
			}

			.card {
				padding: 1.25rem;
				border-radius: 16px;
				background: rgba(8, 12, 24, 0.72);
				border: 1px solid rgba(85, 242, 255, 0.15);
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.skills-grid {
				display: grid;
				gap: 1rem;
			}

			.skill-card {
				padding: 1rem 1.25rem;
				border-radius: 14px;
				border: 1px solid rgba(155, 91, 255, 0.25);
				background: rgba(8, 10, 20, 0.7);
				display: grid;
				gap: 0.75rem;
			}

			.skill-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
			}

			.skill-level {
				font-family: "IBM Plex Mono", "SFMono-Regular", "Fira Code", monospace;
				font-size: 0.85rem;
				color: var(--accent);
			}

			.skill-track {
				height: 10px;
				border-radius: 999px;
				background: rgba(6, 8, 18, 0.9);
				border: 1px solid rgba(85, 242, 255, 0.2);
				overflow: hidden;
			}

			.skill-fill {
				height: 100%;
				width: var(--skill-level);
				background: linear-gradient(90deg, var(--accent), var(--accent-pink));
				box-shadow: 0 0 12px rgba(85, 242, 255, 0.4);
			}

			.project-card {
				position: relative;
			}

			.card-meta {
				font-size: 0.95rem;
				color: rgba(245, 245, 255, 0.75);
			}

			.project-media {
				border-radius: 14px;
				padding: 0.5rem;
				background: linear-gradient(135deg, rgba(85, 242, 255, 0.2), rgba(155, 91, 255, 0.2));
				border: 1px solid rgba(85, 242, 255, 0.2);
			}

			.project-frame {
				min-height: 150px;
				border-radius: 12px;
				border: 1px solid rgba(85, 242, 255, 0.35);
				background: linear-gradient(160deg, rgba(10, 12, 24, 0.9), rgba(6, 8, 18, 0.8));
				display: flex;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 1rem;
			}

			.project-frame-label {
				font-size: 0.9rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: rgba(245, 247, 255, 0.7);
			}

			.ghost-button {
				width: fit-content;
				font-size: 0.95rem;
				padding: 0.55rem 1.2rem;
			}

			.project-modal {
				border: none;
				padding: 0;
				background: transparent;
				color: inherit;
				max-width: 640px;
				width: 100%;
			}

			.project-modal::backdrop {
				background: var(--overlay);
				backdrop-filter: blur(6px);
			}

			.modal-content {
				background: var(--surface-strong);
				border-radius: 20px;
				border: 1px solid rgba(85, 242, 255, 0.25);
				box-shadow: 0 0 24px rgba(6, 8, 18, 0.8);
				padding: 2rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.modal-header {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1.5rem;
			}

			.modal-title {
				margin: 0.3rem 0 0;
				font-size: 1.6rem;
				color: var(--text);
			}

			.modal-close {
				border: 1px solid var(--border);
				background: rgba(6, 8, 18, 0.7);
				color: var(--text);
				padding: 0.45rem 0.9rem;
				border-radius: 999px;
				font-weight: 600;
				cursor: pointer;
			}

			.modal-body {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.modal-heading {
				margin-top: 0.5rem;
			}

			.modal-list {
				list-style: disc;
				padding-left: 1.2rem;
				margin: 0;
				display: grid;
				gap: 0.4rem;
				color: var(--muted);
			}

			.modal-tech {
				margin-top: 0.75rem;
				color: var(--muted);
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}

			.modal-tech-label {
				font-weight: 600;
				color: var(--text);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				font-size: 0.85rem;
			}

			.blog-list {
				display: grid;
				gap: 1rem;
			}

			.blog-list article {
				padding: 1rem 1.25rem;
				border-radius: 16px;
				background: rgba(8, 12, 24, 0.7);
				border: 1px solid rgba(85, 242, 255, 0.18);
			}

			.timeline {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}

			.timeline li {
				padding: 1rem 1.25rem;
				border-radius: 16px;
				background: rgba(8, 12, 24, 0.7);
				border: 1px solid rgba(85, 242, 255, 0.18);
			}

			.timeline-details {
				margin: 0.75rem 0 0;
				padding-left: 1.1rem;
				color: var(--muted);
				display: grid;
				gap: 0.5rem;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				text-decoration: none;
				color: var(--text);
				border: 1px solid var(--border);
				padding: 0.75rem 1.6rem;
				border-radius: 999px;
				font-weight: 600;
				background: rgba(6, 8, 18, 0.7);
				transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
				cursor: pointer;
			}

			.button.primary {
				background: linear-gradient(120deg, rgba(85, 242, 255, 0.2), rgba(255, 79, 216, 0.2));
				border-color: rgba(85, 242, 255, 0.6);
				box-shadow: 0 0 18px rgba(85, 242, 255, 0.35);
			}

			.button.ghost {
				background: transparent;
				border-color: rgba(155, 91, 255, 0.5);
			}

			.button:hover {
				border-color: var(--accent);
				box-shadow: 0 0 18px var(--glow);
				transform: translateY(-2px);
			}

			.contact-actions {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.email-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--text);
				text-decoration: none;
				font-weight: 600;
				font-size: 1.05rem;
				letter-spacing: 0.02em;
			}

			.email-link:hover {
				color: var(--accent-pink);
			}

			.social-links {
				display: flex;
				gap: 0.75rem;
			}

			.social-link {
				width: 44px;
				height: 44px;
				border-radius: 12px;
				border: 1px solid var(--border);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: var(--text);
				background: rgba(6, 8, 18, 0.7);
				transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
			}

			.social-link svg {
				width: 20px;
				height: 20px;
			}

			.social-link:hover {
				border-color: var(--accent);
				box-shadow: 0 0 14px var(--glow);
				transform: translateY(-2px);
			}

			.glow-divider {
				height: 2px;
				border-radius: 999px;
				background: linear-gradient(90deg, transparent, var(--accent-pink), transparent);
				box-shadow: 0 0 14px rgba(255, 79, 216, 0.45);
				animation: pulse 6s ease-in-out infinite;
				opacity: 0.7;
				margin-top: 1.5rem;
			}

			@keyframes pulse {
				0%,
				100% {
					filter: brightness(0.8);
					transform: scaleX(0.98);
				}
				50% {
					filter: brightness(1.2);
					transform: scaleX(1);
				}
			}

			@media (max-width: 640px) {
				main {
					padding: 2.5rem 1.75rem;
				}

				.hero-grid {
					grid-template-columns: 1fr;
				}

				.hero-actions {
					flex-direction: column;
					align-items: flex-start;
				}

				.top-nav {
					gap: 0.5rem;
				}

				.top-nav a {
					padding: 0.55rem 1rem;
				}

				.nav-row {
					align-items: flex-start;
				}

				.modal-content {
					padding: 1.5rem;
				}
			}
		</style>
	</body>
</html>
