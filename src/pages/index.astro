---
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Projects from "../components/Projects.astro";
import Experience from "../components/Experience.astro";
import Notes from "../components/Notes.astro";
import Contact from "../components/Contact.astro";
import { content, defaultLanguage } from "../data/content";

const t = content[defaultLanguage];
---

<html lang={defaultLanguage}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{t.meta.title}</title>
	</head>
	<body>
		<main>
			<Hero />
			<About />
			<Projects />
			<Experience />
			<Notes />
			<Contact />
		</main>
		<script is:inline define:vars={{ content, defaultLanguage }}>
			const contentData = content;
			const defaultLanguageValue = defaultLanguage;
			const languageButtons = document.querySelectorAll("[data-lang]");
			const i18nElements = document.querySelectorAll("[data-i18n]");
			const modal = document.querySelector("#project-modal");
			const openButtons = document.querySelectorAll("[data-project-open]");
			const modalClose = modal?.querySelector("[data-modal-close]");
			const modalTitle = modal?.querySelector("[data-modal='title']");
			const modalSummary = modal?.querySelector("[data-modal='summary']");
			const modalHighlights = modal?.querySelector("[data-modal='highlights']");
			const modalTech = modal?.querySelector("[data-modal='tech']");
			let activeLanguage = defaultLanguageValue;
			let activeProjectId = null;

			const getValue = (lang, key) => {
				return key.split(".").reduce((acc, part) => acc && acc[part], contentData[lang]);
			};

			const getProject = (lang, id) => {
				return contentData[lang]?.projects?.items?.find((item) => item.id === id);
			};

			const renderModal = (project) => {
				if (!project || !modalTitle || !modalSummary || !modalHighlights || !modalTech) return;
				modalTitle.textContent = project.title;
				modalSummary.textContent = project.summary;
				modalTech.textContent = project.tech;
				modalHighlights.innerHTML = "";
				project.highlights.forEach((highlight) => {
					const item = document.createElement("li");
					item.textContent = highlight;
					modalHighlights.appendChild(item);
				});
			};

			const applyLanguage = (lang) => {
				activeLanguage = lang;
				document.documentElement.lang = lang;
				document.title = contentData[lang]?.meta?.title ?? document.title;
				i18nElements.forEach((el) => {
					const key = el.dataset.i18n;
					if (!key) return;
					const value = getValue(lang, key);
					if (typeof value !== "string") return;
					const attrList = el.dataset.i18nAttr;
					if (attrList) {
						attrList.split(",").forEach((attr) => {
							if (attr.trim()) {
								el.setAttribute(attr.trim(), value);
							}
						});
					}
					if (el.dataset.i18nMode !== "attr") {
						el.textContent = value;
					}
				});
				languageButtons.forEach((button) => {
					const isActive = button.dataset.lang === lang;
					button.setAttribute("aria-pressed", String(isActive));
					button.classList.toggle("is-active", isActive);
				});
				if (activeProjectId && modal?.open) {
					const project = getProject(lang, activeProjectId);
					renderModal(project);
				}
			};

			const openModal = (projectId) => {
				const project = getProject(activeLanguage, projectId);
				if (!project || !modal) return;
				activeProjectId = projectId;
				renderModal(project);
				modal.showModal();
			};

			const closeModal = () => {
				if (!modal) return;
				modal.close();
			};

			const savedLanguage = localStorage.getItem("language");
			applyLanguage(savedLanguage || defaultLanguageValue);

			languageButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const nextLang = button.dataset.lang;
					if (!nextLang) return;
					localStorage.setItem("language", nextLang);
					applyLanguage(nextLang);
				});
			});

			openButtons.forEach((button) => {
				button.addEventListener("click", () => {
					const projectId = button.dataset.projectOpen;
					if (projectId) {
						openModal(projectId);
					}
				});
			});

			modalClose?.addEventListener("click", closeModal);
			modal?.addEventListener("cancel", closeModal);
			modal?.addEventListener("click", (event) => {
				if (event.target === modal) {
					closeModal();
				}
			});
		</script>
		<style is:global>
			:root {
				color-scheme: dark;
				--bg: #0b0c12;
				--surface: rgba(19, 21, 32, 0.75);
				--accent: #7c5cff;
				--text: #f5f5ff;
				--muted: #b6bdd9;
				--border: rgba(124, 92, 255, 0.4);
				--glow: rgba(124, 92, 255, 0.35);
				--overlay: rgba(9, 10, 18, 0.75);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: radial-gradient(circle at top, rgba(124, 92, 255, 0.15), transparent 45%),
					var(--bg);
				color: var(--text);
				font-family: "Inter", "Segoe UI", system-ui, -apple-system, sans-serif;
				display: flex;
				justify-content: center;
				align-items: flex-start;
				padding: 3.5rem 1.5rem 6rem;
			}

			main {
				max-width: 880px;
				width: 100%;
				background: var(--surface);
				border: 1px solid rgba(124, 92, 255, 0.2);
				box-shadow: 0 0 30px rgba(7, 9, 18, 0.9);
				border-radius: 24px;
				padding: 3rem;
				backdrop-filter: blur(12px);
				display: flex;
				flex-direction: column;
				gap: 3rem;
			}

			.site-header {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}

			h1 {
				font-size: clamp(2.5rem, 4vw, 3.6rem);
				margin: 0;
				letter-spacing: 0.02em;
			}

			h2 {
				margin: 0 0 0.75rem;
				font-size: clamp(1.6rem, 3vw, 2.2rem);
			}

			h3 {
				margin: 0 0 0.35rem;
				font-size: 1.1rem;
				color: var(--text);
			}

			h4 {
				margin: 0;
				font-size: 1rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--muted);
			}

			p {
				margin: 0;
				font-size: 1.05rem;
				line-height: 1.6;
				color: var(--muted);
			}

			.headline {
				font-size: 1.15rem;
			}

			.hero-meta {
				font-size: 1rem;
				margin-top: 0.4rem;
				color: rgba(245, 245, 255, 0.8);
			}

			.status-chip {
				margin-top: 0.75rem;
				font-size: 0.9rem;
				padding: 0.35rem 0.9rem;
				border-radius: 999px;
				display: inline-flex;
				border: 1px solid rgba(124, 92, 255, 0.4);
				background: rgba(12, 14, 24, 0.6);
				color: rgba(245, 245, 255, 0.85);
			}

			.label {
				font-family: "IBM Plex Mono", "SFMono-Regular", "Fira Code", monospace;
				font-size: 0.85rem;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--text);
			}

			.top-nav {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
			}

			.nav-row {
				display: flex;
				align-items: flex-end;
				justify-content: space-between;
				gap: 1.5rem;
				flex-wrap: wrap;
			}

			.language-switcher {
				display: flex;
				flex-direction: column;
				gap: 0.5rem;
				align-items: flex-start;
			}

			.language-buttons {
				display: inline-flex;
				gap: 0.5rem;
			}

			.language-button {
				border: 1px solid var(--border);
				background: rgba(12, 14, 24, 0.6);
				color: var(--text);
				padding: 0.4rem 0.9rem;
				border-radius: 999px;
				font-weight: 600;
				cursor: pointer;
				transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
			}

			.language-button.is-active {
				border-color: var(--accent);
				box-shadow: 0 0 12px var(--glow);
			}

			.language-button:hover {
				border-color: var(--accent);
				transform: translateY(-1px);
			}

			.top-nav a {
				text-decoration: none;
				color: var(--text);
				border: 1px solid var(--border);
				padding: 0.65rem 1.2rem;
				border-radius: 999px;
				font-weight: 500;
				letter-spacing: 0.02em;
				background: rgba(12, 14, 24, 0.6);
				box-shadow: 0 0 18px transparent;
				transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
			}

			.top-nav a:hover {
				border-color: var(--accent);
				box-shadow: 0 0 18px var(--glow);
				transform: translateY(-2px);
			}

			.section {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.card-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
				gap: 1.25rem;
			}

			.card {
				padding: 1.25rem;
				border-radius: 16px;
				background: rgba(12, 14, 24, 0.6);
				border: 1px solid rgba(124, 92, 255, 0.2);
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.project-card {
				position: relative;
			}

			.card-meta {
				font-size: 0.95rem;
				color: rgba(245, 245, 255, 0.75);
			}

			.screenshot-placeholder {
				border-radius: 12px;
				border: 1px dashed rgba(124, 92, 255, 0.5);
				background: rgba(12, 14, 24, 0.35);
				color: rgba(245, 245, 255, 0.7);
				padding: 1rem;
				text-align: center;
				font-size: 0.9rem;
				letter-spacing: 0.02em;
			}

			.ghost-button {
				width: fit-content;
				font-size: 0.95rem;
				padding: 0.55rem 1.2rem;
			}

			.project-modal {
				border: none;
				padding: 0;
				background: transparent;
				color: inherit;
				max-width: 640px;
				width: 100%;
			}

			.project-modal::backdrop {
				background: var(--overlay);
				backdrop-filter: blur(6px);
			}

			.modal-content {
				background: rgba(12, 14, 24, 0.95);
				border-radius: 20px;
				border: 1px solid rgba(124, 92, 255, 0.25);
				box-shadow: 0 0 24px rgba(7, 9, 18, 0.8);
				padding: 2rem;
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
			}

			.modal-header {
				display: flex;
				align-items: flex-start;
				justify-content: space-between;
				gap: 1.5rem;
			}

			.modal-title {
				margin: 0.3rem 0 0;
				font-size: 1.6rem;
				color: var(--text);
			}

			.modal-close {
				border: 1px solid var(--border);
				background: rgba(12, 14, 24, 0.6);
				color: var(--text);
				padding: 0.45rem 0.9rem;
				border-radius: 999px;
				font-weight: 600;
				cursor: pointer;
			}

			.modal-body {
				display: flex;
				flex-direction: column;
				gap: 0.75rem;
			}

			.modal-heading {
				margin-top: 0.5rem;
			}

			.modal-list {
				list-style: disc;
				padding-left: 1.2rem;
				margin: 0;
				display: grid;
				gap: 0.4rem;
				color: var(--muted);
			}

			.modal-tech {
				margin-top: 0.75rem;
				color: var(--muted);
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
			}

			.modal-tech-label {
				font-weight: 600;
				color: var(--text);
				letter-spacing: 0.08em;
				text-transform: uppercase;
				font-size: 0.85rem;
			}

			.notes-list {
				display: grid;
				gap: 1rem;
			}

			.notes-list article {
				padding: 1rem 1.25rem;
				border-radius: 16px;
				background: rgba(12, 14, 24, 0.45);
				border: 1px solid rgba(124, 92, 255, 0.2);
			}

			.timeline {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}

			.timeline li {
				padding: 1rem 1.25rem;
				border-radius: 16px;
				background: rgba(12, 14, 24, 0.45);
				border: 1px solid rgba(124, 92, 255, 0.2);
			}

			.timeline-details {
				margin: 0.75rem 0 0;
				padding-left: 1.1rem;
				color: var(--muted);
				display: grid;
				gap: 0.5rem;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				text-decoration: none;
				color: var(--text);
				border: 1px solid var(--border);
				padding: 0.75rem 1.6rem;
				border-radius: 999px;
				font-weight: 600;
				background: rgba(12, 14, 24, 0.6);
				transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
				cursor: pointer;
			}

			.button:hover {
				border-color: var(--accent);
				box-shadow: 0 0 18px var(--glow);
				transform: translateY(-2px);
			}

			.contact-actions {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			.email-link {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				color: var(--text);
				text-decoration: none;
				font-weight: 600;
				font-size: 1.05rem;
				letter-spacing: 0.02em;
			}

			.email-link:hover {
				color: var(--accent);
			}

			.social-links {
				display: flex;
				gap: 0.75rem;
			}

			.social-link {
				width: 44px;
				height: 44px;
				border-radius: 12px;
				border: 1px solid var(--border);
				display: inline-flex;
				align-items: center;
				justify-content: center;
				color: var(--text);
				background: rgba(12, 14, 24, 0.6);
				transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
			}

			.social-link svg {
				width: 20px;
				height: 20px;
			}

			.social-link:hover {
				border-color: var(--accent);
				box-shadow: 0 0 14px var(--glow);
				transform: translateY(-2px);
			}

			.glow-divider {
				height: 2px;
				border-radius: 999px;
				background: linear-gradient(90deg, transparent, var(--accent), transparent);
				box-shadow: 0 0 14px var(--glow);
				animation: pulse 6s ease-in-out infinite;
				opacity: 0.7;
				margin-top: 1.5rem;
			}

			@keyframes pulse {
				0%,
				100% {
					filter: brightness(0.8);
					transform: scaleX(0.98);
				}
				50% {
					filter: brightness(1.2);
					transform: scaleX(1);
				}
			}

			@media (max-width: 640px) {
				main {
					padding: 2.5rem 1.75rem;
				}

				.top-nav {
					gap: 0.5rem;
				}

				.top-nav a {
					padding: 0.55rem 1rem;
				}

				.nav-row {
					align-items: flex-start;
				}

				.modal-content {
					padding: 1.5rem;
				}
			}
		</style>
	</body>
</html>
